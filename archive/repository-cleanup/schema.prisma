// ─────────────────────────── QuikInfra Dynamic RBAC v2 ───────────────────────────
// Org × app-scoped roles with dynamic permission grants. Replaces the old
// hardcoded CnRole / CnPermission / CnRolePermission trio (dropped 2026-05-29).
//
// Tables:
//   CnAppRole              — roles per (orgId, appId). isSystem protects rename/delete.
//   CnRolePermissionV2     — (resource, action) grants attached to a role.
//   CnUserAppRole          — user → role assignment per org. userId → auth.User.
//   CnUserPermissionExtra  — additive per-user grants applied on top of role grants.
//
// Permission catalog lives in src/lib/rbac/permissionsRegistry.ts (open strings,
// no DB enum). Project-scoped roles are not implemented; add a QtProjectRole-style
// model here if site-level scoping becomes a real requirement.

model CnAppRole {
  id              String               @id @default(cuid())
  orgId           String
  appId           String
  name            String
  description     String?
  isSystem        Boolean              @default(false)
  isDefault       Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  createdBy       String?
  app             App                  @relation(fields: [appId], references: [id], onDelete: Cascade)
  org             Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members         CnUserAppRole[]
  rolePermissions CnRolePermissionV2[]

  @@unique([orgId, appId, name])
  @@index([orgId, appId])
  @@map("AppRole")
  @@schema("app_quikinfra")
}

/// Permission grant for a CnAppRole. (resource, action) pairs are validated
/// against src/lib/rbac/permissionsRegistry.ts at save time; the DB itself
/// allows any string so the registry can grow without a migration.
model CnRolePermissionV2 {
  id       String    @id @default(cuid())
  roleId   String
  resource String
  action   String
  role     CnAppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@index([roleId])
  @@map("RolePermission")
  @@schema("app_quikinfra")
}

/// Per-(org, user) role assignment. userId points to auth.User.id, NOT to
/// the local CnUser table — quikinfra is migrating toward central-user-only
/// shape (matches quikscale/quiktrack).
model CnUserAppRole {
  id         String    @id @default(cuid())
  userId     String
  orgId      String
  roleId     String
  assignedAt DateTime  @default(now())
  assignedBy String?
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role       CnAppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, roleId])
  @@index([roleId])
  @@index([userId, orgId])
  @@map("UserAppRole")
  @@schema("app_quikinfra")
}

/// Per-user permission overrides applied ON TOP of the user's role grants.
/// Two flavours, distinguished by the `revoke` flag:
///   - revoke = false (default): ADDITIVE grant — extends a user's access
///     without forking the role. Set via the "Grant Settings access"
///     checkbox and any future "grant individual permission" UI.
///   - revoke = true:            SUBTRACTIVE revoke — strips a permission
///     that the user's role would otherwise grant. Used by the Add User
///     form's module checkboxes: ticking only "Masters" + "Purchase"
///     writes revoke rows for every permission in the other module trees.
///
/// Effective permission set = role_grants ∪ extras(revoke=false) − extras(revoke=true).
model CnUserPermissionExtra {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  resource  String
  action    String
  /// True = subtract this (resource, action) from the user's effective set.
  /// False (default) = additive grant on top of the role.
  revoke    Boolean  @default(false)
  grantedBy String?
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, resource, action])
  @@index([userId, orgId])
  @@map("UserPermissionExtra")
  @@schema("app_quikinfra")
}

/// QuikInfra-specific user profile. Holds the per-app fields shown on the
/// Add User drawer that don't fit central auth.User: department, mobile,
/// mobile-app access flag. firstName/lastName are mirrored here so the
/// QuikInfra UI doesn't need a join into auth.User on every list query.
/// One row per (orgId, userId).
model CnUserProfile {
  id                  String   @id @default(cuid())
  userId              String
  orgId               String
  firstName           String
  lastName            String
  department          String?
  mobile              String?
  mobileAccessEnabled Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  org                 Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@map("User_profiles")
  @@schema("app_quikinfra")
}

/// Project-level scope for a QuikInfra user. Replaces the legacy
/// cn_users.projectsAssigned[] array column with a proper join table so
/// "all users on project X" / "all projects for user Y" become indexed
/// queries. One row per (userId, orgId, projectId).
model CnUserProjectAccess {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  projectId String
  grantedBy String?
  grantedAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, projectId])
  @@index([projectId])
  @@index([orgId, projectId])
  @@map("User_project_access")
  @@schema("app_quikinfra")
}

/// Per-tenant VC OS configuration. 1:1 with Tenant when QuikVC is enabled.
/// Holds VC-specific settings that don't apply to QuikScale tenants.
model VCFundProfile {
  id             String   @id @default(cuid())
  orgId          String   @unique
  /// Display name for the fund (shown in Fund switcher; v1 = single-fund per tenant)
  fundName       String
  /// Currency code for capital amounts (ISO 4217). Defaults to INR for India.
  currency       String   @default("INR")
  /// IC voting mode for this tenant: "single" or "multi"
  icVotingMode   String   @default("single")
  /// Quorum count for "multi" mode (ignored when icVotingMode = "single")
  icQuorum       Int      @default(2)
  /// Threshold for "multi" mode: "simple-majority" | "two-thirds" | "unanimous"
  icThreshold    String   @default("simple-majority")
  /// Voting visibility: "open" (voters see each other's vote) or "anonymous"
  icVisibility   String   @default("open")
  /// Tenant's investment thesis — used by Claude for sourced-opportunity scoring
  thesis         String?
  /// Daily summary cron — local hour (0–23) in tenant locale
  dailyBriefHour Int      @default(6)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  updatedBy      String?
  org            Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@schema("app_quikvc")
}

/// Industry / sector vertical (e.g., SaaS, FinTech). Per-tenant configurable.
/// Default seed: 7 verticals (SaaS, FinTech, AgriTech, HealthTech & D2C,
/// Logistics & SupplyChain, ConsumerInternet & E-commerce, DeepTech & AI).
model VCVertical {
  id                   String                 @id @default(cuid())
  orgId                String
  /// Stable slug (kebab-case) — used in URLs and as scoring criteria foreign key
  slug                 String
  name                 String
  description          String?
  /// Display order in admin / pickers
  sortOrder            Int                    @default(0)
  enabled              Boolean                @default(true)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  createdBy            String?
  updatedBy            String?
  applications         VCApplication[]
  deals                VCDeal[]
  scoringCriteria      VCScoringCriterion[]
  sourcedOpportunities VCSourcedOpportunity[]
  org                  Org                    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, slug])
  @@index([orgId])
  @@schema("app_quikvc")
}

/// Per-vertical scoring criterion. Weights must sum to 100% per vertical.
/// Used by Claude scoring + analyst override workflow.
model VCScoringCriterion {
  id          String     @id @default(cuid())
  orgId       String
  verticalId  String
  /// Stable slug — referenced by DealScore rows
  slug        String
  name        String
  description String?
  /// Weight 0–100 (integer percentage). Sum across vertical's criteria must = 100
  weight      Int
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String?
  updatedBy   String?
  org         Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vertical    VCVertical @relation(fields: [verticalId], references: [id], onDelete: Cascade)

  @@unique([orgId, verticalId, slug])
  @@index([orgId, verticalId])
  @@schema("app_quikvc")
}

/// Founder-submitted startup application. Master record created on form
/// submit; auto-creates a linked VCDeal at Intake stage.
model VCApplication {
  id           String     @id @default(cuid())
  orgId        String
  /// User ID of the founder (Membership in this tenant with role = "founder")
  founderId    String
  verticalId   String
  /// Display name of the startup
  startupName  String
  contactName  String
  contactEmail String
  contactPhone String?
  website      String?
  sector       String?
  foundedYear  Int?
  teamSize     Int?
  /// Plain-text business description from form
  description  String?
  /// Funding ask in tenant's currency (smallest unit, e.g. paise)
  fundingAsk   BigInt?
  /// One of: "term-loan" | "rbf" | "equity"
  loanType     String?
  /// Tenure in months (for term-loan / RBF)
  tenureMonths Int?
  /// Purpose of funds — short answer
  purpose      String?
  /// Form-bound answers (Step 3 financials, etc.) — variable shape
  formAnswers  Json?
  status       String     @default("submitted")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  createdBy    String?
  updatedBy    String?
  org          Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vertical     VCVertical @relation(fields: [verticalId], references: [id])
  deal         VCDeal?

  @@index([orgId])
  @@index([orgId, founderId])
  @@index([orgId, status])
  @@schema("app_quikvc")
}

/// Core deal record. Drives the 9-stage pipeline + 6-column Kanban view.
/// Sprint 1: holds enough state to render Pipeline + Deal Overview.
model VCDeal {
  id              String                @id @default(cuid())
  orgId           String
  applicationId   String                @unique
  verticalId      String
  /// One of the 9 canonical stages: intake | onboarding | doc-collection |
  /// discovery-call | research | partner-review | ic-review | due-diligence |
  /// final-decision. Tenant can rename / reorder via PipelineStageConfig (Sprint 4).
  currentStage    String                @default("intake")
  /// Closed status when stage reaches final-decision: open | closed-won | closed-lost
  closedStatus    String                @default("open")
  /// Primary analyst (Membership ID with role = "analyst" or "partner")
  analystId       String?
  /// Optional partner assigned for visibility
  partnerId       String?
  /// AI composite score (0-100) computed from all DealScore rows
  aiScore         Int?
  /// Analyst composite score (overrides AI when set)
  analystScore    Int?
  /// Funding amount allocated so far (sum of DealAllocation amounts; Sprint 4)
  allocatedAmount BigInt                @default(0)
  /// % completion of required documents (0-100)
  docCompleteness Int                   @default(0)
  /// Days the deal has been in its current stage (recomputed by background job)
  daysInStage     Int                   @default(0)
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  createdBy       String?
  updatedBy       String?
  comparables     VCComparableCompany[]
  application     VCApplication         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  org             Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vertical        VCVertical            @relation(fields: [verticalId], references: [id])
  allocations     VCDealAllocation[]
  documents       VCDealDocument[]
  questions       VCDealQuestion[]
  scores          VCDealScore[]
  signals         VCDealSignal[]
  icMemos         VCICMemo?
  meetings        VCMeeting[]
  termSheet       VCTermSheet?
  timelineEvents  VCTimelineEvent[]

  @@index([orgId])
  @@index([orgId, currentStage])
  @@index([orgId, verticalId])
  @@index([orgId, analystId])
  @@schema("app_quikvc")
}

/// Append-only timeline event log per deal. Captures stage transitions, doc
/// uploads, score updates, IC votes, allocations — anything the analyst /
/// founder / investor needs to see in chronological order.
///
/// Pattern parallels existing AuditLog (in public schema); this one is
/// scoped per deal and rendered in the Deal Overview / Workbench timeline tab.
model VCTimelineEvent {
  id         String   @id @default(cuid())
  orgId      String
  dealId     String
  /// Event type — extensible enum string for now. See architecture brief §6.
  /// Examples: stage-advanced | doc-uploaded | doc-rejected | score-updated |
  /// memo-generated | ic-vote-cast | capital-allocated | meeting-scheduled
  type       String
  /// Actor's User ID (null for system events like cron, AI background jobs)
  actorId    String?
  /// Human-readable summary shown in timeline UI
  summary    String
  /// Structured event payload (varies by type)
  payload    Json?
  /// Visibility — "internal" (VC team only) | "founder" (also visible in startup portal) | "investor"
  visibility String   @default("internal")
  createdAt  DateTime @default(now())
  deal       VCDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dealId, createdAt])
  @@index([orgId, type])
  @@schema("app_quikvc")
}

/// Document uploaded against a deal. Stored in Vercel Blob (URL field) and
/// classified by category (pitch deck, financials, incorp cert, etc.). Status
/// tracks the VC team's review state visible to the founder in real time.
model VCDealDocument {
  id           String   @id @default(cuid())
  orgId        String
  dealId       String
  /// Document category (slug from VCDocumentRequirement when those land in
  /// Sprint 5; for now a free-text slug like "pitch-deck" / "financials" /
  /// "incorporation" / "gst-returns" / "bank-statements")
  category     String
  /// Display name shown in document vault
  filename     String
  /// MIME type (application/pdf, image/png, etc.)
  mimeType     String
  /// Size in bytes
  sizeBytes    Int
  /// Vercel Blob URL — public read, signed write
  blobUrl      String
  /// Version number — increments when same category is re-uploaded
  version      Int      @default(1)
  /// Review status: "missing" | "under-review" | "accepted" | "rejected"
  status       String   @default("under-review")
  /// When status = "rejected", reason shown to founder
  rejectReason String?
  /// User ID of uploader (founder via founder portal, analyst via deal workspace)
  uploadedById String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  updatedBy    String?
  deal         VCDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dealId])
  @@index([orgId, status])
  @@schema("app_quikvc")
}

/// Q&A thread between analyst and founder against a deal. Analyst posts a
/// question, founder responds. Stored as a single row with optional answer
/// (so the analyst surfaces unanswered questions easily).
model VCDealQuestion {
  id           String    @id @default(cuid())
  orgId        String
  dealId       String
  /// Analyst (Membership ID) who posted the question
  askedById    String
  /// Question text (analyst-side)
  question     String
  /// Founder's response, if any
  answer       String?
  /// Founder's User ID (Membership) — populated when answered
  answeredById String?
  answeredAt   DateTime?
  /// Status: "open" | "answered" | "closed"
  status       String    @default("open")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  deal         VCDeal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org          Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dealId, status])
  @@schema("app_quikvc")
}

/// Per-criterion AI score + analyst override. Sprint 2 stub — Sprint 3
/// extends with score history, override justification fields, AI confidence.
model VCDealScore {
  id             String   @id @default(cuid())
  orgId          String
  dealId         String
  /// References VCScoringCriterion.slug (not FK because criteria can be
  /// renamed / disabled and we want to keep score history)
  criterionSlug  String
  /// AI-generated score 0-100
  aiScore        Int?
  /// Analyst-overridden score (null when not overridden)
  analystScore   Int?
  /// Required when analystScore is set — analyst rationale for override
  overrideReason String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  updatedBy      String?
  deal           VCDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org            Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, dealId, criterionSlug])
  @@index([orgId, dealId])
  @@schema("app_quikvc")
}

/// Auto-detected or manually-added risk signal against a deal.
/// Severity follows the canonical traffic light. Sprint 3a: manual entry +
/// transcript-detected (when Sprint 3b ships meeting transcripts).
model VCDealSignal {
  id          String   @id @default(cuid())
  orgId       String
  dealId      String
  /// Severity: "red" | "amber" | "green"
  severity    String
  /// Source category: "financial" | "compliance" | "transcript" | "manual"
  source      String
  /// Short signal title shown in risk register
  title       String
  /// Detailed description
  description String?
  /// Mitigation plan (analyst-entered)
  mitigation  String?
  /// Status: "open" | "mitigated" | "accepted" | "resolved"
  status      String   @default("open")
  /// Owner — analyst/partner responsible for tracking this signal
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
  deal        VCDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org         Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dealId, status])
  @@index([orgId, severity])
  @@schema("app_quikvc")
}

/// IC Memo — top-level record per deal. Points to the current version.
/// Versions are immutable snapshots; "freeze" promotes the working version
/// to the IC review artifact and stops further edits.
model VCICMemo {
  id               String            @id @default(cuid())
  orgId            String
  dealId           String            @unique
  /// Status: "draft" | "under-review" | "frozen"
  status           String            @default("draft")
  /// Pointer to the current working version (latest unfrozen)
  currentVersionId String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String?
  updatedBy        String?
  currentVersion   VCICMemoVersion?  @relation("CurrentMemoVersion", fields: [currentVersionId], references: [id])
  deal             VCDeal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org              Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  versions         VCICMemoVersion[] @relation("MemoVersions")
  votes            VCICVote[]

  @@index([orgId])
  @@schema("app_quikvc")
}

/// Versioned snapshot of memo content. Sections stored as JSON for editor
/// flexibility (rich text per section + metadata).
model VCICMemoVersion {
  id             String    @id @default(cuid())
  orgId          String
  memoId         String
  /// Sequential version number per memo (1, 2, 3, …)
  version        Int
  /// Sections array — see lib/memo/types.ts for shape:
  /// [{ id, slug, title, contentHtml, generatedBy, generatedAt }]
  sections       Json
  /// Plain-text summary of what changed vs prior version (analyst note)
  changeNote     String?
  /// Source of this version: "claude" (full AI generation) | "analyst-edit" |
  /// "claude-section" (one section AI-generated, rest manual)
  source         String    @default("analyst-edit")
  createdAt      DateTime  @default(now())
  createdBy      String?
  currentForMemo VCICMemo? @relation("CurrentMemoVersion")
  memo           VCICMemo  @relation("MemoVersions", fields: [memoId], references: [id], onDelete: Cascade)
  org            Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([memoId, version])
  @@index([orgId, memoId])
  @@schema("app_quikvc")
}

/// Comparable company added to a deal — for benchmarking + IC context.
/// Sprint 3a: manual add. Sprint 3b: Claude-suggested via prompt against
/// the deal's vertical + description.
model VCComparableCompany {
  id                String   @id @default(cuid())
  orgId             String
  dealId            String
  name              String
  sector            String?
  /// Source: "manual" | "ai-suggested"
  source            String   @default("manual")
  /// Why this comp is relevant (analyst rationale)
  reason            String?
  /// Free-form metrics (revenue, valuation, multiple, etc.) — JSON for shape variability
  metrics           Json?
  /// External link if any (Crunchbase, company site)
  link              String?
  /// True when the analyst has pinned this as the primary benchmark
  pinnedAsBenchmark Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  updatedBy         String?
  deal              VCDeal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org               Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dealId])
  @@schema("app_quikvc")
}

/// Meeting record per deal — discovery calls, partner meetings, etc.
/// Sprint 3a: just CRUD; Sprint 3b adds transcript paste + Claude analysis.
model VCMeeting {
  id              String               @id @default(cuid())
  orgId           String
  dealId          String
  title           String
  /// Scheduled or actual start time
  scheduledAt     DateTime?
  /// Duration in minutes (post-meeting)
  durationMinutes Int?
  /// Meet/Zoom URL or location
  meetingUrl      String?
  /// Type: "discovery-call" | "partner-meeting" | "ic-review" | "follow-up"
  type            String               @default("discovery-call")
  /// Status: "scheduled" | "completed" | "cancelled"
  status          String               @default("scheduled")
  /// JSON array of participant OrgMember IDs + names + roles
  participants    Json?
  /// Analyst pre-meeting notes
  agenda          String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  createdBy       String?
  updatedBy       String?
  deal            VCDeal               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org             Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  transcript      VCMeetingTranscript?

  @@index([orgId, dealId])
  @@index([orgId, status])
  @@schema("app_quikvc")
}

/// Raw transcript text + Claude-extracted analysis. Separate from VCMeeting
/// because transcripts can be large (db.Text) and aren't always present.
model VCMeetingTranscript {
  id         String    @id @default(cuid())
  orgId      String
  meetingId  String    @unique
  /// Raw pasted transcript text
  rawText    String
  /// Claude analysis output — JSON shape:
  /// { summary, keyPoints[], redFlags[], actionItems[], sentiment }
  analysis   Json?
  /// Status: "raw" | "analysed" | "error"
  status     String    @default("raw")
  /// Token usage for cost tracking
  tokensUsed Int?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  meeting    VCMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@schema("app_quikvc")
}

/// IC vote cast against a frozen memo version. Per voter per memo (not
/// per version — voters vote on the frozen artifact). Decision values map
/// to UX blueprint W14: approve / conditional-approve / reject / abstain.
model VCICVote {
  id         String   @id @default(cuid())
  orgId      String
  memoId     String
  voterId    String
  /// Decision: "approve" | "conditional-approve" | "reject" | "abstain"
  decision   String
  /// Rationale shown to peers (per VCFundProfile.icVisibility)
  rationale  String?
  /// Conditions to clear before final approval (only when decision = conditional-approve)
  conditions String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  memo       VCICMemo @relation(fields: [memoId], references: [id], onDelete: Cascade)
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([memoId, voterId])
  @@index([orgId, memoId])
  @@schema("app_quikvc")
}

/// Investor record per tenant — LP, HNI, or angel.
model VCInvestor {
  id                 String                @id @default(cuid())
  orgId              String
  /// Display name (firm or individual)
  name               String
  /// Type: "lp" | "hni" | "angel"
  type               String                @default("lp")
  /// Optional User link if the investor logs into the Investor Portal
  userId             String?
  /// Contact details
  email              String?
  phone              String?
  /// KYC status: "pending" | "verified" | "rejected"
  kycStatus          String                @default("pending")
  /// Account class for accreditation (e.g., "accredited", "qualified")
  accountClass       String?
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdBy          String?
  updatedBy          String?
  capitalCalls       VCCapitalCall[]
  commitments        VCCommitment[]
  allocations        VCDealAllocation[]
  org                Org                   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  repaymentPayments  VCRepaymentPayment[]
  repaymentSchedules VCRepaymentSchedule[]

  @@index([orgId])
  @@index([orgId, type])
  @@schema("app_quikvc")
}

/// Commitment record per investor. One-shot pledge (totalAmount upfront)
/// OR scheduled (callable in tranches via VCCommitmentSchedule child rows).
model VCCommitment {
  id          String     @id @default(cuid())
  orgId       String
  investorId  String
  /// Type: "one-shot" | "scheduled"
  type        String     @default("one-shot")
  /// Total amount committed in paise (smallest INR unit)
  totalAmount BigInt
  /// Currency code (typically INR; per VCFundProfile.currency)
  currency    String     @default("INR")
  /// Vintage year (when the commitment was made)
  vintageYear Int?
  /// Status: "active" | "fulfilled" | "defaulted" | "cancelled"
  status      String     @default("active")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String?
  updatedBy   String?
  investor    VCInvestor @relation(fields: [investorId], references: [id], onDelete: Cascade)
  org         Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, investorId])
  @@schema("app_quikvc")
}

/// Capital call issued to an investor (against an active commitment) to draw
/// down funds for a specific deal allocation. Tracks the lifecycle:
/// issued → paid (or overdue/defaulted on miss).
model VCCapitalCall {
  id           String                 @id @default(cuid())
  orgId        String
  investorId   String
  /// Optional link to the allocation that triggered this call
  allocationId String?
  /// Amount called in paise
  amount       BigInt
  /// Date payment is due
  dueDate      DateTime
  /// Status: "issued" | "paid" | "partial" | "overdue" | "defaulted"
  status       String                 @default("issued")
  /// Sum of all VCCapitalCallPayment amounts so far (denormalized for fast queries)
  paidAmount   BigInt                 @default(0)
  paidAt       DateTime?
  notes        String?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  createdBy    String?
  updatedBy    String?
  investor     VCInvestor             @relation(fields: [investorId], references: [id], onDelete: Cascade)
  org          Org                    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payments     VCCapitalCallPayment[]

  @@index([orgId, investorId, status])
  @@index([orgId, dueDate])
  @@schema("app_quikvc")
}

/// Payment received against a capital call. Supports partial payments.
model VCCapitalCallPayment {
  id            String        @id @default(cuid())
  orgId         String
  capitalCallId String
  amount        BigInt
  paidAt        DateTime
  reference     String?
  notes         String?
  createdAt     DateTime      @default(now())
  createdBy     String?
  capitalCall   VCCapitalCall @relation(fields: [capitalCallId], references: [id], onDelete: Cascade)
  org           Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, capitalCallId])
  @@schema("app_quikvc")
}

/// Allocation of capital to a deal. Multiple investors per deal allowed.
/// Rolls into VCDeal.allocatedAmount (denormalized for fast queries).
model VCDealAllocation {
  id          String     @id @default(cuid())
  orgId       String
  dealId      String
  investorId  String
  /// Amount allocated in paise
  amount      BigInt
  /// Status: "pending" | "confirmed" | "disbursed"
  status      String     @default("pending")
  /// Disbursed date once funds move (after capital calls clear)
  disbursedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  createdBy   String?
  updatedBy   String?
  deal        VCDeal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  investor    VCInvestor @relation(fields: [investorId], references: [id])
  org         Org        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([dealId, investorId])
  @@index([orgId, dealId])
  @@index([orgId, investorId])
  @@schema("app_quikvc")
}

/// Repayment schedule per deal × investor. Type determines structure:
/// - "emi": fixed monthly EMI for term loans, schedule generated upfront
/// - "equity-exit": no fixed schedule; payments recorded on liquidity events
/// - "rbf": revenue-based — payments recorded as % of monthly revenue
model VCRepaymentSchedule {
  id            String               @id @default(cuid())
  orgId         String
  dealId        String
  investorId    String
  /// Type: "emi" | "equity-exit" | "rbf"
  type          String
  /// Total expected repayment principal + interest (paise)
  totalExpected BigInt
  /// Total received so far (denormalized from VCRepaymentPayment)
  totalPaid     BigInt               @default(0)
  /// EMI schedule details when type = "emi"
  /// JSON: [{ dueDate, amount, status: "due"|"paid"|"overdue" }]
  scheduleJson  Json?
  /// Status: "active" | "completed" | "defaulted" | "exited"
  status        String               @default("active")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  createdBy     String?
  updatedBy     String?
  payments      VCRepaymentPayment[]
  investor      VCInvestor           @relation(fields: [investorId], references: [id])
  org           Org                  @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, dealId])
  @@index([orgId, investorId])
  @@schema("app_quikvc")
}

/// Repayment payment received from the startup back to investors.
model VCRepaymentPayment {
  id         String              @id @default(cuid())
  orgId      String
  scheduleId String
  investorId String
  amount     BigInt
  paidAt     DateTime
  /// "principal" | "interest" | "exit" — for rolling up
  category   String              @default("principal")
  reference  String?
  notes      String?
  createdAt  DateTime            @default(now())
  createdBy  String?
  investor   VCInvestor          @relation(fields: [investorId], references: [id])
  org        Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  schedule   VCRepaymentSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([orgId, scheduleId])
  @@index([orgId, investorId, paidAt])
  @@schema("app_quikvc")
}

/// Per-tenant term sheet template. Contains rich-text body with {{variable}}
/// placeholders that get substituted from deal data at generation time.
/// Only Fund Admin edits this. v1 supports a single template per tenant.
model VCTermSheetTemplate {
  id        String   @id @default(cuid())
  orgId     String
  name      String   @default("Default Term Sheet")
  /// Rich-text body with {{startup.name}} / {{deal.fundingAsk}} etc.
  bodyHtml  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
  updatedBy String?
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@index([orgId])
  @@schema("app_quikvc")
}

/// Generated term sheet for a deal. 1:1 — re-generation creates a new version
/// referenced via the rendered HTML in renderedBodyHtml + version counter.
model VCTermSheet {
  id               String    @id @default(cuid())
  orgId            String
  dealId           String    @unique
  /// Sequential version (1, 2, 3, …) — increments on every regen
  version          Int       @default(1)
  /// Rendered HTML (variables already substituted)
  renderedBodyHtml String
  /// Status: "draft" | "sent" | "signed"
  status           String    @default("draft")
  sentAt           DateTime?
  signedAt         DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?
  updatedBy        String?
  deal             VCDeal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  org              Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@schema("app_quikvc")
}

/// Inbound deal-flow item before a formal application is submitted.
/// Created via manual entry, CSV upload, or email-forward parser.
/// Converts → VCApplication + VCDeal once analyst clicks "Convert to deal".
model VCSourcedOpportunity {
  id                     String      @id @default(cuid())
  orgId                  String
  /// Source: "manual" | "csv" | "email" | "referral"
  source                 String      @default("manual")
  /// Free-form startup name
  startupName            String
  /// Optional contact details
  contactName            String?
  contactEmail           String?
  contactPhone           String?
  website                String?
  /// Funding ask in paise (optional at sourcing stage)
  fundingAsk             BigInt?
  /// Free-form pitch / one-liner
  pitch                  String?
  /// Vertical assignment (set by analyst or thesis-fit auto-suggest)
  verticalId             String?
  /// AI-computed thesis-fit score 0-100 (Claude per fund's verticals/criteria)
  thesisFitScore         Int?
  /// AI rationale for thesis-fit score
  thesisFitReason        String?
  /// Status: "new" | "reviewing" | "qualified" | "converted" | "rejected"
  status                 String      @default("new")
  /// Once converted → links to created application
  convertedApplicationId String?
  /// Free-form notes
  notes                  String?
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  createdBy              String?
  updatedBy              String?
  org                    Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  vertical               VCVertical? @relation(fields: [verticalId], references: [id])

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@schema("app_quikvc")
}

/// In-app notifications for users. Triggered from key lifecycle events
/// (allocation, schedule created, payment received, vote settled, etc.).
/// Email is sent in parallel via Resend; this row tracks the in-app feed.
model VCNotification {
  id        String    @id @default(cuid())
  orgId     String
  /// Recipient User.id
  userId    String
  /// Event type: "allocation" | "repayment-schedule" | "repayment-payment"
  /// | "vote-cast" | "vote-settled" | "stage-advanced" | "memo-frozen"
  /// | "deal-assigned" | "term-sheet-generated"
  type      String
  /// Short headline
  title     String
  /// Optional body
  body      String?
  /// Optional deep-link target inside the app
  href      String?
  /// Read state
  readAt    DateTime?
  createdAt DateTime  @default(now())
  org       Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, userId, readAt])
  @@index([orgId, userId, createdAt])
  @@schema("app_quikvc")
}

/// Audit log for QuikVC. Captures security-sensitive events:
/// - Forbidden access (403 from RBAC gate)
/// - Successful privileged actions (allocation, ic-settle, term-sheet-generate, etc.)
/// - Admin config changes (verticals, scoring criteria, fund profile, term-sheet template)
///
/// Append-only. Never edit or delete rows. Retention policy is enforced by
/// a periodic cleanup job (Sprint 6 — currently keeps everything).
model VCAuditLog {
  id        String   @id @default(cuid())
  orgId     String
  /// Actor user id (may be null for system / cron jobs)
  userId    String?
  /// Action: "rbac.deny" | "allocation.create" | "ic.settle" | "term-sheet.generate" |
  /// "vertical.update" | "scoring-criterion.update" | "fund-profile.update" |
  /// "term-sheet-template.update" | etc.
  action    String
  /// Optional resource id this event acts on (deal id, investor id, etc.)
  resource  String?
  /// HTTP outcome — useful for separating allowed vs denied
  outcome   String   @default("ok")
  /// Free-form metadata (request path, role, error message, payload digest, etc.)
  metadata  Json?
  /// IP for forensics
  ipAddress String?
  /// User agent for forensics
  userAgent String?
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([orgId, action, createdAt])
  @@index([orgId, userId, createdAt])
  @@index([orgId, outcome, createdAt])
  @@schema("app_quikvc")
}

model QtProject {
  id          String            @id @default(cuid())
  orgId       String
  projectKey  String
  name        String
  description String?
  projectType String            @default("software")
  icon        String?
  color       String?           @default("#2563eb")
  status      String            @default("active")
  startDate   DateTime?
  endDate     DateTime?
  leadUserId  String?
  isDeleted   Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   String?
  updatedBy   String?
  docs        QtDoc[]
  issues      QtIssue[]
  statuses    QtIssueStatus[]
  issueTypes  QtIssueType[]
  pages       QtPage[]
  taskGroups  QtTaskGroup[]
  org              Org                 @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members          QtProjectMember[]
  teams            QtProjectTeam[]
  sprints          QtSprint[]
  projectRoles     QtProjectRole[]
  projectUserRoles QtProjectUserRole[]

  @@unique([orgId, projectKey])
  @@index([orgId, status])
  @@index([leadUserId])
  @@schema("app_quiktrack")
}

model QtProjectMember {
  id        String    @id @default(cuid())
  projectId String
  userId    String
  /// Legacy enum (PROJECT_ADMIN / MEMBER / VIEWER) kept for back-compat with
  /// existing withProjectAccess checks. Dynamic per-project role assignment
  /// lives in QtProjectUserRole.
  role      String    @default("MEMBER")
  invitedBy String?
  joinedAt  DateTime  @default(now())
  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   QtProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId, role])
  @@index([userId])
  @@schema("app_quiktrack")
}

// ─────────────────────────── QuikTrack RBAC ───────────────────────────
// Two role layers sharing the SAME rule tables (QtRolePermission /
// QtRoleNavigation):
//   • QtAppRole      — app-wide roles (org × app scope)
//   • QtProjectRole  — project-scoped roles (project scope)
// A rule row belongs to exactly one of (roleId, projectRoleId).
// QtUserAppRole assigns an AppRole to a user in an org.
// QtProjectMember.projectRoleId assigns a ProjectRole to a project member.

model QtAppRole {
  id          String             @id @default(cuid())
  orgId       String
  appId       String
  name        String
  description String?
  isSystem    Boolean            @default(false)
  isDefault   Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  createdBy   String?
  app         App                @relation(fields: [appId], references: [id], onDelete: Cascade)
  org         Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  navigations      QtRoleNavigation[]
  permissions      QtRolePermission[]
  fieldPermissions QtRoleFieldPermission[]
  members          QtUserAppRole[]

  @@unique([orgId, appId, name])
  @@index([orgId, appId])
  @@map("AppRole")
  @@schema("app_quiktrack")
}

model QtProjectRole {
  id               String                         @id @default(cuid())
  orgId            String
  projectId        String
  name             String
  description      String?
  isDefault        Boolean                        @default(false)
  createdAt        DateTime                       @default(now())
  updatedAt        DateTime                       @updatedAt
  createdBy        String?
  org              Org                            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project          QtProject                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  permissions      QtProjectRolePermission[]
  navigations      QtProjectRoleNavigation[]
  fieldPermissions QtProjectRoleFieldPermission[]
  members          QtProjectUserRole[]

  @@unique([projectId, name])
  @@index([orgId])
  @@index([projectId])
  @@schema("app_quiktrack")
}

/// Permission grant for an app-wide role (Layer 1). Project-scoped role
/// grants live in QtProjectRolePermission — separate table per the
/// schema rule (no polymorphic columns on existing tables).
model QtRolePermission {
  id       String    @id @default(cuid())
  roleId   String
  resource String
  action   String
  role     QtAppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@index([roleId])
  @@map("RolePermission")
  @@schema("app_quiktrack")
}

/// Navigation grant for an app-wide role (Layer 1).
model QtRoleNavigation {
  id     String    @id @default(cuid())
  roleId String
  navKey String
  role   QtAppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, navKey])
  @@index([roleId])
  @@map("RoleNavigation")
  @@schema("app_quiktrack")
}

/// Field-level permission grant for an app-wide role (Layer 1). Captures
/// "what level can role X interact with field F on entity E" — one of
/// hidden / readonly / editable / required. Absence of a row means default
/// (today: "editable") so initial DB state matches today's behavior.
model QtRoleFieldPermission {
  id     String    @id @default(cuid())
  roleId String
  entity String
  field  String
  level  String    // "hidden" | "readonly" | "editable" | "required"
  role   QtAppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, entity, field])
  @@index([roleId, entity])
  @@map("RoleFieldPermission")
  @@schema("app_quiktrack")
}

/// Permission grant for a project-scoped role (Layer 2). Separate table from
/// QtRolePermission so the FK to QtProjectRole stays strict.
model QtProjectRolePermission {
  id            String        @id @default(cuid())
  projectRoleId String
  resource      String
  action        String
  projectRole   QtProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)

  @@unique([projectRoleId, resource, action])
  @@index([projectRoleId])
  @@schema("app_quiktrack")
}

/// Field-level permission grant for a project-scoped role (Layer 2). One row
/// per (projectRoleId, entity, field). Absence means default level (editable).
model QtProjectRoleFieldPermission {
  id            String        @id @default(cuid())
  projectRoleId String
  entity        String
  field         String
  level         String        // "hidden" | "readonly" | "editable" | "required"
  projectRole   QtProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)

  @@unique([projectRoleId, entity, field])
  @@index([projectRoleId, entity])
  @@map("ProjectRoleFieldPermission")
  @@schema("app_quiktrack")
}

/// Navigation grant for a project-scoped role (Layer 2). Reserved for future
/// per-project sidebar filtering — not consumed by the current sidebar.
model QtProjectRoleNavigation {
  id            String        @id @default(cuid())
  projectRoleId String
  navKey        String
  projectRole   QtProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)

  @@unique([projectRoleId, navKey])
  @@index([projectRoleId])
  @@schema("app_quiktrack")
}

/// Per-(project, user) dynamic role assignment (Layer 2). Replaces the
/// QtProjectMember.projectRoleId column that was rolled back. Membership
/// presence stays in QtProjectMember; the dynamic role lives here.
model QtProjectUserRole {
  id            String        @id @default(cuid())
  projectId     String
  userId        String
  projectRoleId String
  assignedAt    DateTime      @default(now())
  assignedBy    String?
  project       QtProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectRole   QtProjectRole @relation(fields: [projectRoleId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, projectId])
  @@index([projectRoleId])
  @@schema("app_quiktrack")
}

model QtUserAppRole {
  id         String    @id @default(cuid())
  userId     String
  orgId      String
  roleId     String
  assignedAt DateTime  @default(now())
  assignedBy String?
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role       QtAppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, roleId])
  @@index([roleId])
  @@index([userId, orgId])
  @@map("UserAppRole")
  @@schema("app_quiktrack")
}

/// Per-user additive permission grants for QuikTrack — applied ON TOP of
/// the user's role grants.
model QtUserPermissionExtra {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  resource  String
  action    String
  grantedBy String?
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, resource, action])
  @@index([userId, orgId])
  @@map("UserPermissionExtra")
  @@schema("app_quiktrack")
}


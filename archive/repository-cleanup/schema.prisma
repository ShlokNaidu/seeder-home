  updatedBy        String?
  deletedAt        DateTime?
  convertedBoq     CnBOQ?             @relation("EstimationToBoq", fields: [convertedBoqId], references: [id])
  org              Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project          CnProject          @relation(fields: [projectId], references: [id])
  items            CnEstimationItem[]

  @@unique([orgId, estimationNumber])
  @@index([orgId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@schema("app_quikinfra")
}

model CnEstimationItem {
  id           String             @id @default(cuid())
  estimationId String

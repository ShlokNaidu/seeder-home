generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
  schemas   = ["app_quikinfra", "app_quikscale", "app_quiksocial", "app_quiktrack", "app_quikvc", "auth", "public", "quikit"]
}

model App {
  id               String           @id @default(cuid())
  name             String
  slug             String           @unique
  description      String?
  iconUrl          String?
  baseUrl          String
  status           String           @default("active")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  /// When true, only OrgMembers with role super_admin/org_admin (or User.isSuperAdmin)
  /// can see/launch this app from the org's tile grid. Set on Admin Portal and
  /// any future ops/billing surface. Default false for product apps.
  requiresOrgAdmin Boolean          @default(false)
  appRoles         AppRole[]
  AppRole          QtAppRole[]
  cnAppRoles       CnAppRole[]
  healthChecks     AppHealthCheck[]
  moduleFlags      AppModuleFlag[]
  oauthClient      OAuthClient?
  tenantAccess     OrgAppAccess[]
  userAccess       UserAppAccess[]

  @@index([slug])
  @@index([status])
  @@schema("quikit")
}

model OAuthClient {
  id           String   @id @default(cuid())
  appId        String   @unique
  clientId     String   @unique
  clientSecret String
  redirectUris String[]
  scopes       String[] @default(["openid", "profile", "email", "tenant"])
  grantTypes   String[] @default(["authorization_code", "refresh_token"])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  app          App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@schema("quikit")
}

model OAuthCode {
  id                  String   @id @default(cuid())
  code                String   @unique
  clientId            String
  userId              String
  orgId               String
  scopes              String[]
  codeChallenge       String?
  codeChallengeMethod String?
  redirectUri         String
  expiresAt           DateTime
  used                Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([code])
  @@index([expiresAt])
  @@schema("quikit")
}

model OAuthRefreshToken {
  id          String   @id @default(cuid())
  token       String   @unique
  accessToken String?  @unique
  clientId    String
  userId      String
  orgId       String
  scopes      String[]
  expiresAt   DateTime
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([token])
  @@index([accessToken])
  @@index([userId, clientId])
  @@schema("quikit")
}

model UserAppAccess {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  appId     String
  role      String   @default("member")
  grantedBy String?
  grantedAt DateTime @default(now())
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId, appId])
  @@index([userId])
  @@index([orgId])
  @@index([appId])
  @@schema("quikit")
}


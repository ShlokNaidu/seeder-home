  @@unique([clientId, userId])
  @@index([orgId])
  @@index([clientId])
  @@index([userId])
  @@schema("app_quikscale")
}

/// Standalone Client Member entity (spec §3). Flat list of name + email
/// records — the "Client Members" page is a simple data-entry table. These
/// are distinct from tenant Users (which handle login/auth).
///
/// Future integration point: Client Master's multi-lookup picker will pick
/// from these records instead of (or in addition to) tenant Users.
model ClientMember {
  id                String                               @id @default(cuid())
  orgId             String
  name              String
  email             String
  createdAt         DateTime                             @default(now())
  updatedAt         DateTime                             @updatedAt
  createdBy         String
  updatedBy         String?
  deletedAt         DateTime?
  dailyAbsences     ClientDailyHuddleTeamAbsence[]
  org               Org                                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  clientLinks       ClientTeamMember[]
  weeklyAbsences    ClientWeeklyMeetingTeamAbsence[]
  weeklyDashboardNA ClientWeeklyMeetingTeamDashboardNA[]
  weeklyScores      ClientWeeklyMemberScore[]

  @@index([orgId])
  @@index([orgId, deletedAt])
  @@index([email])
  @@schema("app_quikscale")
}

model ClientDailyHuddle {
  id                  String                         @id @default(cuid())
  orgId               String
  clientId            String
  meetingDate         DateTime
  callStatus          ClientMeetingStatus            @default(HELD)
  /// Actual observed start/end (HH:mm 24h). Blank when call not held.
  actualStartTime     String?
  actualEndTime       String?
  /// Three format checks + a punctuality override radio (see meetingrythm.md §4).
  format1Status       ClientMeetingFlag              @default(NA)
  format2Status       ClientMeetingFlag              @default(NA)
  stuckCallStatus     ClientMeetingFlag              @default(NA)
  punctualityOverride ClientMeetingFlag              @default(NA)
  /// Snapshot of invited roster size at meeting time (used in attendance math).
  totalMembers        Int                            @default(0)
  /// Rich-text notes captured in the drawer (image 1).
  notes               String?
  notesKPDashboard    String?
  otherNotes          String?
  createdAt           DateTime                       @default(now())
  updatedAt           DateTime                       @updatedAt
  createdBy           String
  updatedBy           String?
  deletedAt           DateTime?
  client              Client                         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  org                 Org                            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  absentMembers       ClientDailyHuddleAbsence[]
  absentTeamMembers   ClientDailyHuddleTeamAbsence[]

  @@index([orgId])
  @@index([orgId, deletedAt])
  @@index([clientId])
  @@index([meetingDate])
  @@index([clientId, meetingDate])
  @@index([clientId, deletedAt, meetingDate])
  @@index([deletedAt])
  @@schema("app_quikscale")
}

model ClientDailyHuddleAbsence {
  huddleId String
  userId   String
  huddle   ClientDailyHuddle @relation(fields: [huddleId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([huddleId, userId])
  @@index([userId])
  @@schema("app_quikscale")
}

/// Per-huddle absence link for external Client Members (distinct from the
/// legacy tenant-User link above). Used by the Daily Huddle drawer.
model ClientDailyHuddleTeamAbsence {
  huddleId       String
  clientMemberId String
  member         ClientMember      @relation(fields: [clientMemberId], references: [id], onDelete: Cascade)
  huddle         ClientDailyHuddle @relation(fields: [huddleId], references: [id], onDelete: Cascade)

  @@id([huddleId, clientMemberId])
  @@index([clientMemberId])
  @@schema("app_quikscale")
}

model ClientWeeklyMeeting {
  id                     String                               @id @default(cuid())
  orgId                  String
  clientId               String
  meetingDate            DateTime
  callStatus             ClientMeetingStatus                  @default(HELD)
  /// Free-text label entered when callStatus = OTHER. NULL otherwise.
  /// API handler enforces this invariant on every write.
  callStatusOther        String?
  /// Overall actual start/end (HH:mm).
  actualStartTime        String?
  actualEndTime          String?
  /// Segment timings (7 slots — mirrors spec's time-2..time-8).
  /// Null = segment skipped. HH:mm strings.
  segmentTime1           String?
  segmentTime2           String?
  segmentTime3           String?
  segmentTime4           String?
  segmentTime5           String?
  segmentTime6           String?
  segmentTime7           String?
  /// Per-meeting punctuality override. UI label: "Planned Deviation In Time".
  /// YES → call treated as punctual regardless of actualStartTime (an agreed
  /// schedule deviation was honored). NO / NA → fall through to the regular
  /// "actualStart <= plannedStart + 60s grace" check in clientMeetingsMath.
  /// Mirrors ClientDailyHuddle.punctualityOverride.
  punctualityOverride    ClientMeetingFlag                    @default(NA)
  /// Radio flags — order matches the form spec (Good News → OPSP Review).
  /// Each pairs with segmentTime1..7 for "<flag> Time" companion field.
  goodNewsSharing        ClientMeetingFlag                    @default(NA)
  kpDashboard            ClientMeetingFlag                    @default(NA)
  gaps                   ClientMeetingFlag                    @default(NA)
  www                    ClientMeetingFlag                    @default(NA)
  feedback               ClientMeetingFlag                    @default(NA)
  collectiveIntelligence ClientMeetingFlag                    @default(NA)
  opspReview             ClientMeetingFlag                    @default(NA)
  notesKPDashboard       String?
  otherNotes             String?
  createdAt              DateTime                             @default(now())
  updatedAt              DateTime                             @updatedAt
  createdBy              String
  updatedBy              String?
  deletedAt              DateTime?
  client                 Client                               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  org                    Org                                  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  absentMembers          ClientWeeklyMeetingAbsence[]
  dashboardNAMembers     ClientWeeklyMeetingDashboardNA[]
  logs                   ClientWeeklyMeetingLog[]
  absentTeamMembers      ClientWeeklyMeetingTeamAbsence[]
  dashboardNATeamMembers ClientWeeklyMeetingTeamDashboardNA[]
  memberScores           ClientWeeklyMemberScore[]

  @@index([orgId])
  @@index([orgId, deletedAt])
  @@index([clientId])
  @@index([meetingDate])
  @@index([clientId, meetingDate])
  @@index([clientId, deletedAt, meetingDate])
  @@index([deletedAt])
  @@schema("app_quikscale")
}

model ClientWeeklyMeetingAbsence {
  meetingId String
  userId    String
  meeting   ClientWeeklyMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetingId, userId])
  @@index([userId])

model QtIssue {
  id               String             @id @default(cuid())
  orgId            String
  projectId        String
  key              String
  title            String
  description      String?
  type             String             @default("TASK")
  statusId         String
  priority         String             @default("MEDIUM")
  parentId         String?
  epicId           String?
  sprintId         String?
  assigneeId       String?
  reporterId       String?
  startDate        DateTime?
  dueDate          DateTime?
  eta              Float?
  storyPoints      Int?
  orderInColumn    Int                @default(0)
  /// Grouped Kanban — visual business band. INDEPENDENT of statusId.
  /// Dragging across groups must NOT change status, and changing status
  /// must NOT change groupId. Null = tasks render under the default
  /// "Ungrouped" row but still carry no group assignment.
  groupId          String?
  orderInGroup     Int                @default(0)
  isDeleted        Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  createdBy        String?
  updatedBy        String?
  epic             QtIssue?           @relation("IssueEpic", fields: [epicId], references: [id])
  epicChildren     QtIssue[]          @relation("IssueEpic")
  org              Org                @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent           QtIssue?           @relation("IssueParent", fields: [parentId], references: [id])
  children         QtIssue[]          @relation("IssueParent")
  project          QtProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint           QtSprint?          @relation(fields: [sprintId], references: [id])
  status           QtIssueStatus      @relation(fields: [statusId], references: [id])
  group            QtTaskGroup?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  comments         QtIssueComment[]
  history          QtIssueHistory[]
  outgoingLinks    QtIssueLink[]      @relation("IssueLinkSource")
  incomingLinks    QtIssueLink[]      @relation("IssueLinkTarget")
  timesheetEntries QtTimesheetEntry[]

  @@unique([projectId, key])
  @@index([orgId])
  @@index([projectId, statusId])
  @@index([projectId, type])
  @@index([assigneeId])
  @@index([epicId])
  @@index([parentId])
  @@index([sprintId])
  @@index([groupId, orderInGroup])
  @@index([startDate, dueDate])
  @@schema("app_quiktrack")
}

/// Grouped Kanban — business-band grouping that sits alongside `statusId`
/// as an independent axis on QtIssue. The "group ≠ status" rule is enforced
/// in app code (apps/quiktrack/lib/services/groupService.ts), not at the DB
/// layer.
model QtTaskGroup {
  id          String    @id @default(cuid())
  orgId       String
  projectId   String
  name        String
  /// Hex color used to render the group band accent.
  color       String    @default("#94a3b8")
  /// Optional lucide-react icon name.
  icon        String?
  order       Int       @default(0)
  /// True for the auto-seeded "Ungrouped" row. Cannot be deleted; tasks
  /// fall back here when any other group is deleted.
  isDefault   Boolean   @default(false)
  /// Board-wide default collapse state. Per-user override is client-side.
  isCollapsed Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  project     QtProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  issues      QtIssue[]

  @@unique([projectId, name])
  @@index([orgId, projectId])
  @@index([projectId, order])
  @@schema("app_quiktrack")
}


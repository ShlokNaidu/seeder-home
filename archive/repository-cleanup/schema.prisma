model CnRAB {
  id                String            @id @default(cuid())
  orgId             String
  rabNumber         String
  projectId         String
  boqId             String
  rabDate           DateTime
  /// Sequential bill number per project (1st RAB, 2nd RAB, …)
  billSeqNo         Int
  billedTillDate    DateTime
  /// Snapshot at time of RAB: cumulative billed before THIS bill.
  priorBilledAmount Decimal           @default(0) @db.Decimal(18, 2)
  /// This period's amount = sum of lines' currentPeriodAmount
  currentBillAmount Decimal           @default(0) @db.Decimal(18, 2)
  subtotal          Decimal           @default(0) @db.Decimal(18, 2)
  taxAmount         Decimal           @default(0) @db.Decimal(18, 2)
  total             Decimal           @default(0) @db.Decimal(18, 2)
  status            String            @default("draft")
  remarks           String?
  approvedAt        DateTime?
  approvedBy        String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  createdBy         String
  updatedBy         String?
  deletedAt         DateTime?
  invoices          CnClientInvoice[]
  boq               CnBOQ             @relation(fields: [boqId], references: [id])
  org               Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project           CnProject         @relation(fields: [projectId], references: [id])
  lines             CnRABLine[]

  @@unique([orgId, rabNumber])
  @@unique([projectId, billSeqNo])
  @@index([orgId])
  @@index([projectId])
  @@index([boqId])
  @@index([status])
  @@index([deletedAt])
  @@schema("app_quikinfra")
}

model CnRABLine {
  id                  String    @id @default(cuid())
  rabId               String
  boqItemId           String
  /// Cumulative work done (in uom) TILL the end of this RAB's period.
  cumulativeQtyDone   Decimal   @db.Decimal(18, 4)
  /// Snapshot at time of RAB: cumulative qty before THIS bill.
  priorCumulativeQty  Decimal   @default(0) @db.Decimal(18, 4)
  /// = cumulative − prior. The qty billed in THIS period.
  currentPeriodQty    Decimal   @db.Decimal(18, 4)
  /// Rate taken from the BOQ at time of RAB creation (so historical RABs are stable).
  rate                Decimal   @db.Decimal(18, 2)
  /// currentPeriodQty × rate
  currentPeriodAmount Decimal   @db.Decimal(18, 2)
  gstRate             Decimal?  @db.Decimal(5, 2)
  taxAmount           Decimal   @default(0) @db.Decimal(18, 2)
  remarks             String?
  boqItem             CnBOQItem @relation(fields: [boqItemId], references: [id])
  rab                 CnRAB     @relation(fields: [rabId], references: [id], onDelete: Cascade)

  @@index([rabId])
  @@index([boqItemId])
  @@schema("app_quikinfra")
}

model CnClientInvoice {
  id            String                      @id @default(cuid())
  orgId         String
  invoiceNumber String
  customerId    String
  projectId     String?
  rabId         String?
  invoiceDate   DateTime
  dueDate       DateTime?
  subtotal      Decimal                     @default(0) @db.Decimal(18, 2)
  taxAmount     Decimal                     @default(0) @db.Decimal(18, 2)
  /// GST split (additive; legacy rows zero, taxAmount stays authoritative total).
  cgstAmount    Decimal                     @default(0) @db.Decimal(18, 2)
  sgstAmount    Decimal                     @default(0) @db.Decimal(18, 2)
  igstAmount    Decimal                     @default(0) @db.Decimal(18, 2)
  /// 2-char state code — intra-state (CGST+SGST) vs inter-state (IGST).
  placeOfSupply String?
  total         Decimal                     @default(0) @db.Decimal(18, 2)
  paidAmount    Decimal                     @default(0) @db.Decimal(18, 2)
  status        String                      @default("draft")
  remarks       String?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  createdBy     String
  updatedBy     String?
  deletedAt     DateTime?
  customer      CnCustomer                  @relation(fields: [customerId], references: [id])
  org           Org                         @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project       CnProject?                  @relation(fields: [projectId], references: [id])
  rab           CnRAB?                      @relation(fields: [rabId], references: [id])
  lines         CnClientInvoiceLine[]
  allocations   CnClientReceiptAllocation[]
  creditNotes   CnCreditNote[]

  @@unique([orgId, invoiceNumber])
  @@index([orgId])
  @@index([customerId])
  @@index([projectId])
  @@index([rabId])
  @@index([status])
  @@index([deletedAt])
  @@schema("app_quikinfra")
}

model CnClientReceipt {

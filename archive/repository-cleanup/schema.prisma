  name                    String
  slug                    String                   @unique
  description             String?
  status                  String                   @default("active")
  fiscalYearStart         Int                      @default(1)
  quarterStartMonth       Int                      @default(1)
  weekStartDay            Int                      @default(1)
  logoUrl                 String?
  brandColor              String?                  @default("#0066cc")
  plan                    String                   @default("startup")
  billingEmail            String?
  /// Empty = no restriction. Non-empty = POST /api/members must match one
  /// (case-insensitive, no @ prefix — e.g. ["acme.com", "acme.co.uk"]).
  allowedEmailDomains     String[]                 @default([])
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdBy               String?
  cnApprovalRequests      CnApprovalRequest[]
  cnApprovalRules         CnApprovalRule[]
  cnAssets                CnAsset[]
  cnAttendances           CnAttendance[]
  cnAuditLogs             CnAuditLog[]
  cnBoqs                  CnBOQ[]
  cnBanks                 CnBank[]
  cnClientInvoices        CnClientInvoice[]
  cnClientReceipts        CnClientReceipt[]
  cnCompanies             CnCompany[]
  cnContractors           CnContractor[]
  cnCostCenters           CnCostCenter[]
  cnCreditNotes           CnCreditNote[]
  cnCustomers             CnCustomer[]
  cnDprs                  CnDPR[]
  cnDebitNotes            CnDebitNote[]
  cnDepartments           CnDepartment[]
  cnDieselLogs            CnDieselLog[]
  cnDocuments             CnDocument[]
  cnEmployees             CnEmployee[]
  cnEstimations           CnEstimation[]
  cnExpenses              CnExpense[]
  cnFinancialYears        CnFinancialYear[]
  cnGstCodes              CnGSTCode[]
  cnGatePasses            CnGatePass[]
  cnGoodReturns           CnGoodReturn[]
  cnGRNs                  CnGoodsReceiptNote[]
  cnHindrances            CnHindrance[]
  cnInternalReturns       CnInternalReturn[]
  cnItems                 CnItem[]
  cnItemGroups            CnItemGroup[]
  cnLocations             CnLocation[]
  cnMachinery             CnMachinery[]
  cnMaterialIssues        CnMaterialIssue[]
  cnNumberSequences       CnNumberSequence[]
  cnPayrolls              CnPayroll[]
  cnProjects              CnProject[]
  cnPurchaseIndents       CnPurchaseIndent[]
  cnPurchaseOrders        CnPurchaseOrder[]
  cnPurchaseRequisitions  CnPurchaseRequisition[]
  cnQcInspections         CnQCInspection[]
  cnRabs                  CnRAB[]
  cnRFQs                  CnRFQ[]
  cnSafetyChecklists      CnSafetyChecklist[]
  cnSafetyIncidents       CnSafetyIncident[]
  cnStockLedger           CnStockLedger[]
  cnStockReconciliations  CnStockReconciliation[]
  cnStockTransfers        CnStockTransfer[]
  cnTdsCodes              CnTDSCode[]
  cnTermsConditions       CnTermsCondition[]
  cnUoms                  CnUOM[]
  cnVendors               CnVendor[]
  cnVendorBills           CnVendorBill[]
  cnVendorPayments        CnVendorPayment[]
  cnWorkCategories        CnWorkCategory[]
  cnWorkOrders            CnWorkOrder[]
  cnAppRoles              CnAppRole[]
  cnUserAppRoles          CnUserAppRole[]
  cnUserPermissionExtras  CnUserPermissionExtra[]
  cnUserProfiles          CnUserProfile[]
  cnUserProjectAccess     CnUserProjectAccess[]
  accountabilityFunctions AccountabilityFunction[]
  appRoles                AppRole[]
  categoryMasters         CategoryMaster[]
  clients                 Client[]
  clientDailyHuddles      ClientDailyHuddle[]
  clientMembers           ClientMember[]
  clientWeeklyMeetings    ClientWeeklyMeeting[]
  feedbackEntries         FeedbackEntry[]
  goals                   Goal[]
  habits                  HabitAssessment[]
  kpis                    KPI[]
  opspData                OPSPData[]
  opspDocuments           OPSPDocument[]
  opppPlans               OPSPPlan[]
  opspReviewEntries       OPSPReviewEntry[]
  oneOnOnes               OneOnOne[]
  performanceReviews      PerformanceReview[]
  priorities              Priority[]
  quarterSettings         QuarterSetting[]
  talentAssessments       TalentAssessment[]
  userAppRoles            UserAppRole[]
  userPermissionExtras    UserPermissionExtra[]
  userTablePreferences    UserTablePreference[]
  wwwItems                WWWItem[]
  brands                  Brand[]
  AppRole                 QtAppRole[]
  QtProjectRole           QtProjectRole[]
  QtDashboard             QtDashboard[]
  QtDoc                   QtDoc[]
  QtInvitation            QtInvitation[]
  qtIssues                QtIssue[]
  qtProjects              QtProject[]
  qtTeams                 QtTeam[]
  QtTimesheetEntry        QtTimesheetEntry[]
  QtUserActivity          QtUserActivity[]
  QtUserViewPref          QtUserViewPref[]
  UserAppRole             QtUserAppRole[]
  UserPermissionExtra     QtUserPermissionExtra[]
  vcApplications          VCApplication[]
  vcAuditLogs             VCAuditLog[]
  vcCapitalCalls          VCCapitalCall[]
  vcCapitalCallPayments   VCCapitalCallPayment[]
  vcCommitments           VCCommitment[]
  vcComparableCompanies   VCComparableCompany[]
  vcDeals                 VCDeal[]
  vcDealAllocations       VCDealAllocation[]
  vcDealDocuments         VCDealDocument[]
  vcDealQuestions         VCDealQuestion[]
  vcDealScores            VCDealScore[]
  vcDealSignals           VCDealSignal[]
  vcFundProfile           VCFundProfile?
  vcICMemos               VCICMemo[]
  vcICMemoVersions        VCICMemoVersion[]
  vcICVotes               VCICVote[]
  vcInvestors             VCInvestor[]
  vcMeetings              VCMeeting[]
  vcMeetingTranscripts    VCMeetingTranscript[]
  vcNotifications         VCNotification[]
  vcRepaymentPayments     VCRepaymentPayment[]
  vcRepaymentSchedules    VCRepaymentSchedule[]
  vcScoringCriteria       VCScoringCriterion[]
  vcSourcedOpportunities  VCSourcedOpportunity[]
  vcTermSheets            VCTermSheet[]
  vcTermSheetTemplates    VCTermSheetTemplate[]
  vcTimelineEvents        VCTimelineEvent[]
  vcVerticals             VCVertical[]
  appModuleFlags          AppModuleFlag[]
  auditLogs               AuditLog[]
  featureFlags            FeatureFlag[]
  invoices                Invoice[]
  notifications           Notification[]
  sessionEvents           SessionEvent[]
  teams                   Team[]
  userTeams               UserTeam[]
  tenantAppAccess         OrgAppAccess[]
  users                   OrgMember[]
  userAppAccess           UserAppAccess[]

  @@index([slug])
  @@index([status])
  @@schema("quikit")
}

model User {
  id                      String                           @id @default(cuid())
  email                   String                           @unique
  emailVerified           DateTime?
  password                String?
  firstName               String
  lastName                String
  avatar                  String?
  isSuperAdmin            Boolean                          @default(false)
  country                 String?
  timezone                String?
  bio                     String?
  themeMode               String?                          @default("light")
  accentColor             String?                          @default("#0066cc")
  kpiFrozenCol            String?
  priorityFrozenCol       String?
  wwwFrozenCol            String?
  kpiHiddenCols           String?
  priorityHiddenCols      String?
  wwwHiddenCols           String?
  kpiSort                 String?
  prioritySort            String?
  wwwSort                 String?
  kpiColWidths            String?
  priorityColWidths       String?
  wwwColWidths            String?
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  lastSignInAt            DateTime?
  /// FRD FR-SA-009 / BR-008 — true when the user was created via a native
  /// email invite and is still on the system default password (Quikit2026).
  /// On first login the auth flow routes them to /set-password instead of
  /// the dashboard. Cleared once they save a new password (or click Skip,
  /// because BR-008 says the screen is shown only once).
  mustChangePassword      Boolean                          @default(false)
  accountabilityFunctions AccountabilityFunction[]
  dailyHuddleAbsences     ClientDailyHuddleAbsence[]
  clientMemberships       ClientMembership[]
  weeklyMeetingAbsences   ClientWeeklyMeetingAbsence[]
  weeklyDashboardNAs      ClientWeeklyMeetingDashboardNA[]
  feedbackGiven           FeedbackEntry[]                  @relation("FeedbackFrom")
  feedbackReceived        FeedbackEntry[]                  @relation("FeedbackTo")
  goalsOwned              Goal[]                           @relation("GoalOwner")
  kpisOwned               KPI[]                            @relation("KPIOwner")
  kpiNotes                KPINote[]
  opspData                OPSPData[]
  opppPlan                OPSPPlan?
  opspReviewEntries       OPSPReviewEntry[]
  oneOnOnesAsManager      OneOnOne[]                       @relation("OneOnOneManager")
  oneOnOnesAsReport       OneOnOne[]                       @relation("OneOnOneReport")
  reviewsReceived         PerformanceReview[]              @relation("ReviewsReceived")
  reviewsGiven            PerformanceReview[]              @relation("ReviewsGiven")
  prioritiesOwned         Priority[]                       @relation("PriorityOwner")
  talentAssessor          TalentAssessment[]               @relation("TalentAssessor")
  talentAssessed          TalentAssessment[]               @relation("TalentAssessed")
  appRoles                UserAppRole[]
  permissionExtras        UserPermissionExtra[]
  tablePreferences        UserTablePreference[]
  UserAppRole             QtUserAppRole[]
  UserPermissionExtra     QtUserPermissionExtra[]
  qtProjectUserRoles      QtProjectUserRole[]
  cnUserAppRoles          CnUserAppRole[]
  cnPermissionExtras      CnUserPermissionExtra[]
  cnProfiles              CnUserProfile[]
  cnProjectAccess         CnUserProjectAccess[]
  accounts                Account[]
  sessions                Session[]
  verificationTokens      VerificationToken[]
  sessionEvents           SessionEvent[]
  userTeams               UserTeam[]
  memberships             OrgMember[]
  appAccess               UserAppAccess[]

  @@index([email])
  @@schema("auth")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  token_type        String?
  scope             String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@schema("auth")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  expires      DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("auth")
}

/// Email verification + password reset tokens for the central auth app (`apps/auth`).
model VerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  type      String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("auth")
}

/// Audit row written by `POST /api/auth/internal/issue-agent-jwt` on every
/// attempt — success and failure. `status` distinguishes outcomes; `errorCode`
/// is set on non-success rows to mirror the API error envelope. No FK to User
/// because we want to log issuance attempts even for unknown userIds (which is
/// itself a useful security signal).
model AgentJwtIssuance {
  id                String   @id @default(cuid())
  requestingService String
  userId            String
  orgId             String
  agentId           String?
  reason            String
  ttlSeconds        Int
  actingAs          String
  traceId           String?
  status            String
  errorCode         String?
  issuedAt          DateTime @default(now())

  @@index([userId, issuedAt])
  @@index([requestingService, issuedAt])
  @@schema("auth")
}

model OrgMember {
  id                String    @id @default(cuid())
  orgId             String
  userId            String
  role              String
  teamId            String?
  customPermissions String[]
  invitationToken   String?   @unique
  invitedAt         DateTime?
  acceptedAt        DateTime?
  status            String    @default("active")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdBy         String?
  /// FRD FR-SA-002 / FR-OA-002 — apps to grant on accept. Replaces the old
  /// auto-grant-all-active-apps behaviour. Empty = no app access (only valid
  /// for role=member per FR-OA-003).
  inviteAppIds      String[]  @default([])
  /// FRD §3.3 / §3.4 — "sso" or "native". Drives which onboarding email is sent,
  /// which CTA is rendered, and whether the accept flow goes through the
  /// Set-Password screen. Null for legacy memberships created before the FRD.
  inviteMethod      String?
  /// FRD §3.3 — for SSO invites we classify the invited email's provider at
  /// invite time so the email template can render "Sign in with Google" vs
  /// "Sign in with Microsoft". One of: "google" | "microsoft" | null.
  inviteProvider    String?
  org               Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team              Team?     @relation(fields: [teamId], references: [id])
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
  @@index([userId, status])
  @@index([userId, orgId, status])
  @@index([teamId])
  @@index([role])
  @@index([orgId, role])
  @@schema("quikit")
}

model UserTeam {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  teamId    String
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, teamId])
  @@index([orgId])
  @@index([userId])
  @@index([teamId])
  @@schema("public")
}

model Team {
  id                      String                   @id @default(cuid())
  orgId                   String
  name                    String
  description             String?
  slug                    String
  parentTeamId            String?
  headId                  String?
  color                   String?                  @default("#0066cc")
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  createdBy               String?
  deletedAt               DateTime?
  accountabilityFunctions AccountabilityFunction[]
  kpis                    KPI[]
  priorities              Priority[]
  org                     Org                      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentTeam              Team?                    @relation("TeamHierarchy", fields: [parentTeamId], references: [id])
  childTeams              Team[]                   @relation("TeamHierarchy")
  userTeams               UserTeam[]
  members                 OrgMember[]

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([parentTeamId])
  @@index([deletedAt])
  @@schema("public")
}

model AccountabilityFunction {
  id               String                   @id @default(cuid())
  orgId            String
  name             String
  description      String?
  teamId           String?
  parentFunctionId String?
  assignedToUserId String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  assignedTo       User?                    @relation(fields: [assignedToUserId], references: [id])
  org              Org                      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parentFunction   AccountabilityFunction?  @relation("FunctionHierarchy", fields: [parentFunctionId], references: [id])
  childFunctions   AccountabilityFunction[] @relation("FunctionHierarchy")
  team             Team?                    @relation(fields: [teamId], references: [id])

  @@unique([orgId, name])
  @@index([orgId])
  @@index([assignedToUserId])
  @@schema("app_quikscale")
}

model KPI {
  id                 String           @id @default(cuid())
  orgId              String
  name               String
  description        String?
  kpiLevel           String           @default("individual")
  owner              String?
  ownerIds           String[]         @default([])
  ownerContributions Json?
  teamId             String?
  parentKPIId        String?
  quarter            String           @default("Q1")
  year               Int
  measurementUnit    String
  target             Float?
  quarterlyGoal      Float?
  qtdGoal            Float?
  qtdAchieved        Float?
  currentWeekValue   Float?
  progressPercent    Float?           @default(0)
  status             String           @default("active")
  healthStatus       String           @default("on-track")
  divisionType       String           @default("Cumulative")
  weeklyTargets      Json?
  weeklyOwnerTargets Json?
  currency           String?
  targetScale        String?
  reverseColor       Boolean          @default(false)
  frequency          String           @default("weekly")
  lastNotes          String?
  lastNotesAt        DateTime?
  lastNotedBy        String?
  deletedAt          DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdBy          String
  updatedBy          String?
  org                Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner_user         User?            @relation("KPIOwner", fields: [owner], references: [id])
  parentKPI          KPI?             @relation("KPICascade", fields: [parentKPIId], references: [id])
  childKPIs          KPI[]            @relation("KPICascade")
  team               Team?            @relation(fields: [teamId], references: [id])
  logs               KPILog[]
  notes              KPINote[]
  weeklyValues       KPIWeeklyValue[]

  @@index([orgId])
  @@index([orgId, deletedAt])
  @@index([orgId, kpiLevel, deletedAt])
  @@index([owner])
  @@index([teamId])
  @@index([kpiLevel])
  @@index([parentKPIId])
  @@index([status])
  @@index([healthStatus])
  @@index([quarter, year])
  @@schema("app_quikscale")
}

model KPIWeeklyValue {
  id         String   @id @default(cuid())
  orgId      String
  kpiId      String
  userId     String?
  weekNumber Int
  value      Float?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String
  updatedBy  String?
  kpi        KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@unique([kpiId, userId, weekNumber])
  @@index([orgId])
  @@index([kpiId])
  @@index([userId])
  @@schema("app_quikscale")
}

model KPINote {
  id        String   @id @default(cuid())
  orgId     String
  kpiId     String
  content   String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  kpi       KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([kpiId])
  @@index([authorId])
  @@schema("app_quikscale")
}

model KPILog {
  id        String   @id @default(cuid())
  orgId     String
  kpiId     String
  action    String
  oldValue  String?
  newValue  String?
  changedBy String
  reason    String?
  createdAt DateTime @default(now())
  kpi       KPI      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([kpiId])
  @@index([createdAt])
  @@index([kpiId, createdAt])
  @@schema("app_quikscale")
}

model Priority {
  id             String                 @id @default(cuid())
  orgId          String
  name           String
  description    String?
  owner          String
  teamId         String?
  quarter        String
  year           Int
  startWeek      Int?
  endWeek        Int?
  overallStatus  String                 @default("not-started")
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  createdBy      String
  updatedBy      String?
  deletedAt      DateTime?
  org            Org                    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner_user     User                   @relation("PriorityOwner", fields: [owner], references: [id])
  team           Team?                  @relation(fields: [teamId], references: [id])
  weeklyStatuses PriorityWeeklyStatus[]

  @@index([orgId])
  @@index([orgId, deletedAt])
  @@index([orgId, year, quarter, deletedAt])
  @@index([owner])
  @@index([teamId])
  @@index([quarter, year])
  @@index([orgId, owner])
  @@index([deletedAt])
  @@schema("app_quikscale")
}

model PriorityWeeklyStatus {
  id         String   @id @default(cuid())
  priorityId String
  weekNumber Int
  status     String
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  updatedBy  String?
  priority   Priority @relation(fields: [priorityId], references: [id], onDelete: Cascade)

  @@unique([priorityId, weekNumber])
  @@index([priorityId])
  @@schema("app_quikscale")
}

model WWWItem {
  id               String           @id @default(cuid())
  orgId            String
  who              String
  what             String
  when             DateTime
  linkedPriorityId String?
  linkedKPIId      String?
  status           String           @default("not-started")
  notes            String?
  category         String?
  originalDueDate  DateTime?
  revisedDates     String[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  createdBy        String
  updatedBy        String?
  deletedAt        DateTime?
  whoIds           String[]         @default([])
  org              Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  revisionLogs     WWWRevisionLog[]

  @@index([orgId])
  @@index([who])
  @@index([when])
  @@index([status])
  @@index([createdAt])
  @@index([orgId, who])
  @@index([orgId, deletedAt])
  @@index([orgId, status, deletedAt])
  @@index([deletedAt])
  @@schema("app_quikscale")
}

model WWWRevisionLog {
  id         String   @id @default(cuid())
  wwwItemId  String
  oldDueDate DateTime
  newDueDate DateTime
  reason     String?
  changedBy  String
  createdAt  DateTime @default(now())
  wwwItem    WWWItem  @relation(fields: [wwwItemId], references: [id], onDelete: Cascade)

  @@index([wwwItemId])
  @@index([createdAt])
  @@schema("app_quikscale")
}

model CategoryMaster {
  id            String   @id @default(cuid())
  orgId         String
  name          String
  nameKey       String
  dataType      String
  currency      String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String
  /// Distribution shape — drives the row balance/validation matrix in OPSP modals.
  /// One of: "Cumulative" | "CumulativeTillEnd" | "Standalone".
  categoryType  String   @default("Cumulative")
  /// Fill mode — "Manual" requires the user to enter every cell;
  /// "Automatic" lets `calculateBreakdown` distribute Projected across periods.
  breakdownType String   @default("Automatic")
  org           Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, nameKey, dataType, currency], name: "category_tenant_name_type_currency_uniq")
  @@index([orgId])
  @@index([dataType])
  @@schema("app_quikscale")
}


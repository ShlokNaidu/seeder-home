}

model Campaign {
  id                  String     @id @default(cuid())
  orgId               String
  brandId             String
  name                String
  describeConcept     String?
  objective           String
  status              String     @default("draft")
  startDate           DateTime
  endDate             DateTime
  frequency           String
  weeklyDay           Int?
  monthlyDate         Int?
  postTime            String     @default("09:00")
  timezone            String     @default("UTC")
  totalPosts          Int        @default(0)
  generatedPosts      Int        @default(0)
  failedPosts         Int        @default(0)
  includeLogo         Boolean    @default(true)
  productIds          String[]   @default([])
  serviceIds          String[]   @default([])
  assetIds            String[]   @default([])
  themeRotationPlan   Json?
  brandColorPrimary   String?
  brandColorSecondary String?
  brandColorAccent    String?
  celeryTaskId        String?
  templateId          String?
  clonedFromId        String?
  lastGeneratedAt     DateTime?
  attachedProduct     Json?
  attachedService     Json?
  attachedAsset       Json?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  createdBy           String?
  updatedBy           String?
  brand               Brand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  clonedFrom          Campaign?  @relation("CampaignClone", fields: [clonedFromId], references: [id])
  clones              Campaign[] @relation("CampaignClone")
  posts               Post[]

  @@index([orgId])
  @@index([orgId, brandId])
  @@index([orgId, brandId, status])
  @@index([orgId, startDate, endDate])
  @@index([orgId, status])
  @@schema("app_quiksocial")
}

model Post {
  id                          String         @id @default(cuid())
  orgId                       String
  brandId                     String
  campaignId                  String?
  socialAccountId             String?
  moderatedById               String?
  title                       String?
  content                     String
  prompt                      String?
  platform                    String
  status                      String         @default("draft")
  rejectionNote               String?
  scheduledFor                DateTime?
  requestedPublishTime        DateTime?
  approvedAt                  DateTime?
  moderatedAt                 DateTime?
  moderationStatus            String?
  moderationNote              String?
  publishedAt                 DateTime?
  publishedMediaId            String?
  permalink                   String?
  failedReason                String?
  lockedAt                    DateTime?
  isAiGenerated               Boolean        @default(false)
  aiImageUrl                  String?
  imageUrls                   String[]       @default([])
  videoUrl                    String?
  aiVideoUrl                  String?
  aiVideoTranscript           String?
  youtubeTitle                String?
  youtubeDescription          String?
  youtubePrivacy              String?
  pinterestBoardId            String?
  pinterestLink               String?
  selectedProductIds          String[]       @default([])
  selectedServiceIds          String[]       @default([])
  selectedAssetIds            String[]       @default([])
  selectedAssetUrlsById       Json?
  displayImagesByVariantLabel Json?
  platformPostIds             Json?
  attachedProduct             Json?
  attachedService             Json?
  attachedAsset               Json?
  storeidead                  Json?
  newPostCreateMeta           Json?
  likes                       Int            @default(0)
  comments                    Int            @default(0)
  shares                      Int            @default(0)
  reactions                   Int            @default(0)
  engagementUpdatedAt         DateTime?
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt
  createdBy                   String?
  updatedBy                   String?
  brand                       Brand          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  campaign                    Campaign?      @relation(fields: [campaignId], references: [id])
  socialAccount               SocialAccount? @relation(fields: [socialAccountId], references: [id])

  @@index([orgId])
  @@index([orgId, brandId, scheduledFor])
  @@index([orgId, brandId, status])
  @@index([orgId, campaignId, status])
  @@index([orgId, createdBy])
  @@index([orgId, moderationStatus])
  @@index([orgId, publishedAt])
  @@index([orgId, status])
  @@index([orgId, status, scheduledFor, approvedAt, lockedAt])
  @@schema("app_quiksocial")
}

model Product {
  id                  String   @id @default(cuid())
  orgId               String
  brandId             String
  name                String
  description         String?
  price               String?
  currency            String?
  sku                 String?
  category            String?
  tone                String?
  imageUrls           String[] @default([])
  videoUrls           String[] @default([])
  tags                String[] @default([])
  idealCustomerTitles String[] @default([])
  problemsSolved      String[] @default([])
  proofPoints         String[] @default([])
  isActive            Boolean  @default(true)
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  createdBy           String?
  updatedBy           String?
  brand               Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, brandId])
  @@index([orgId, brandId, isActive, createdAt(sort: Desc)])
  @@index([orgId, isActive])
  @@schema("app_quiksocial")
}

model Service {
  id          String   @id @default(cuid())
  orgId       String
  brandId     String
  name        String
  description String?
  pricing     String?
  currency    String?
  duration    String?
  category    String?
  imageUrls   String[] @default([])
  videoUrls   String[] @default([])
  tags        String[] @default([])
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
  brand       Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([orgId, brandId])
  @@index([orgId, brandId, isActive, createdAt(sort: Desc)])
  @@index([orgId, isActive])
  @@schema("app_quiksocial")
}

model SocialAccount {
  id             String    @id @default(cuid())
  orgId          String
  brandId        String?
  userId         String
  platform       String
  accountId      String
  pageId         String?
  accountName    String
  profilePicture String?
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?
  posts          Post[]
  brand          Brand?    @relation(fields: [brandId], references: [id])

  @@unique([orgId, userId, platform, accountId])
  @@index([orgId])
  @@index([orgId, brandId])
  @@index([orgId, isActive])
  @@index([orgId, platform])
  @@schema("app_quiksocial")
}

model UserPreference {
  id              String   @id @default(cuid())
  orgId           String
  userId          String
  activeBrandId   String?
  backgroundImage String   @default("New_light_green_background_final.webp")
  defaultPostTime String   @default("09:00")
  aiPreferences   Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  activeBrand     Brand?   @relation(fields: [activeBrandId], references: [id])

  @@unique([orgId, userId])
  @@index([userId])
  @@schema("app_quiksocial")
}

model QtFeedback {
  id         String   @id @default(cuid())
  orgId      String
  userId     String
  projectId  String?
  category   String
  content    String
  contactOk  Boolean  @default(false)
  researchOk Boolean  @default(false)
  url        String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([userId])
  @@schema("app_quiktrack")
}

/// Radio-style tri-state used by every format / punctuality / quality flag.
enum ClientMeetingFlag {
  YES
  NO
  NA

  @@schema("app_quikscale")
}

/// Call status for daily huddles and weekly meetings.
enum ClientMeetingStatus {
  HELD
  NOT_HELD
  CALL_CANCELLED_BY_CLIENT
  HOLIDAY_FOR_CLIENT
  HOLIDAY_FOR_SUCCESS_ALCHEMIST
  OTHER

  @@schema("app_quikscale")
}

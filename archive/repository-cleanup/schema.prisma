/// Raw log of every API request across all apps. 30-day retention policy
/// (cleanup cron at /api/super/cron/cleanup-api-calls). Aggregated hourly
/// into ApiCallHourlyRollup for long-term trend analysis.
model ApiCall {
  id          String   @id @default(cuid())
  orgId       String?
  userId      String?
  appSlug     String
  method      String
  path        String
  pathPattern String
  statusCode  Int
  durationMs  Int
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([appSlug, createdAt])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@schema("public")
}

/// Hourly aggregation of ApiCall rows. Source of truth for all per-tenant
/// analytics older than a few hours. Populated by /api/super/cron/rollup-api-calls.
model ApiCallHourlyRollup {
  id              String   @id @default(cuid())
  orgId           String?
  appSlug         String
  hourBucket      DateTime
  method          String
  pathPattern     String
  statusClass     String
  callCount       Int      @default(0)
  errorCount      Int      @default(0)
  totalDurationMs BigInt   @default(0)
  maxDurationMs   Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([orgId, appSlug, hourBucket, method, pathPattern, statusClass])
  @@index([orgId, hourBucket])
  @@index([appSlug, hourBucket])
  @@index([hourBucket])
  @@schema("public")
}


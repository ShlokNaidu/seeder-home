  @@index([isActive])
  @@schema("public")
}

/// SA-D — Impersonation session record.
///
/// A super admin clicks "View as" on a tenant, which creates one of these
/// rows with a short-lived single-use token. The target app validates the
/// token, signs the super admin in AS the target user (with the
/// impersonation flag carried in the JWT), and deletes the token.
///
/// All actions during impersonation are tagged with impersonatingSuperAdminId
/// in the audit log so customer-support activity is distinguishable from
/// user activity.
model Impersonation {
  id            String    @id @default(cuid())
  /// User who initiated the impersonation (a platform super admin).
  superAdminId  String
  /// The tenant whose app is being accessed.
  targetOrgId   String
  /// The user whose identity will be assumed (usually an org admin).
  targetUserId  String
  /// Which app to land in after token exchange ("quikscale" | "admin").
  targetAppSlug String
  /// Opaque single-use token — 32-byte base64url. Consumed on accept.
  token         String    @unique
  /// Absolute expiry — rejected after this regardless of usage.
  expiresAt     DateTime
  /// Populated when the token is redeemed; null means still pending.
  acceptedAt    DateTime?
  /// Populated when the super admin explicitly exits the session.
  exitedAt      DateTime?
  /// Free-form reason captured at start time for audit.
  reason        String?
  ipAddress     String?
  createdAt     DateTime  @default(now())

  @@index([superAdminId, createdAt])
  @@index([targetOrgId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([expiresAt])
  @@schema("public")
}

/// Platform alerts raised by the alerts engine cron. Super admins see these
/// as a dismissable list on the Analytics dashboard. Sparse — rows only
/// exist for currently-firing conditions. Resolved alerts are soft-deleted
/// by setting resolvedAt.
model PlatformAlert {
  id             String    @id @default(cuid())
  rule           String
  severity       String    @default("warning")
  title          String
  message        String
  /// Free-form identifier for the alert subject (appId, orgId, etc) — used
  /// for dedupe so the same condition doesn't fire twice.
  subjectKey     String
  /// Optional link for click-through ("/organizations/<orgId>")
  link           String?
  data           Json?
  firstSeenAt    DateTime  @default(now())
  lastSeenAt     DateTime  @default(now())
  resolvedAt     DateTime?
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([resolvedAt])
  @@index([severity, lastSeenAt])
  @@index([rule, subjectKey, resolvedAt])
  @@schema("public")
}


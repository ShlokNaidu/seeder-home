  machinery      CnMachinery? @relation(fields: [machineryId], references: [id])
  org            Org          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project        CnProject    @relation(fields: [projectId], references: [id])

  @@unique([orgId, logNumber])
  @@index([orgId])
  @@index([projectId])
  @@index([deletedAt])
  @@schema("app_quikinfra")
}

model CnBOQ {
  id              String         @id @default(cuid())
  orgId           String
  projectId       String
  boqNumber       String
  boqDate         DateTime
  currency        String         @default("INR")
  subtotal        Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal        @default(0) @db.Decimal(18, 2)
  total           Decimal        @default(0) @db.Decimal(18, 2)
  status          String         @default("draft")
  lockedAt        DateTime?
  lockedBy        String?
  remarks         String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  createdBy       String
  updatedBy       String?
  deletedAt       DateTime?
  org             Org            @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project         CnProject      @relation(fields: [projectId], references: [id])
  items           CnBOQItem[]
  fromEstimations CnEstimation[] @relation("EstimationToBoq")
  rabs            CnRAB[]

  @@unique([orgId, boqNumber])
  @@index([orgId])
  @@index([projectId])
  @@index([status])
  @@index([deletedAt])
  @@schema("app_quikinfra")
}

model CnBOQItem {
  id              String      @id @default(cuid())
  boqId           String
  /// Parent in the BOQ tree (null for top-level). Children's rates/amounts
  /// roll up to the parent's `amount` (computed, not stored).
  parentId        String?
  /// Display order within siblings.
  sortOrder       Int         @default(0)
  /// When kind="group" description is a header, quantity/rate/uom are null.
  /// When kind="item" everything must be present.
  kind            String      @default("item")
  code            String?
  description     String
  itemId          String?
  uomId           String?
  quantity        Decimal?    @db.Decimal(18, 4)
  rate            Decimal?    @db.Decimal(18, 2)
  amount          Decimal     @default(0) @db.Decimal(18, 2)
  gstRate         Decimal?    @db.Decimal(5, 2)
  scheduledStart  DateTime?
  scheduledEnd    DateTime?
  percentComplete Decimal?    @db.Decimal(5, 2)
  boq             CnBOQ       @relation(fields: [boqId], references: [id], onDelete: Cascade)
  item            CnItem?     @relation(fields: [itemId], references: [id])
  parent          CnBOQItem?  @relation("CnBOQItemHierarchy", fields: [parentId], references: [id])
  children        CnBOQItem[] @relation("CnBOQItemHierarchy")
  uom             CnUOM?      @relation(fields: [uomId], references: [id])
  dprLines        CnDPRLine[]
  rabLines        CnRABLine[]

  @@index([boqId])
  @@index([parentId])
  @@index([itemId])
  @@schema("app_quikinfra")
}

model CnDPR {
  id                    String          @id @default(cuid())
  orgId                 String
  projectId             String
  dprDate               DateTime
  weather               String?
  reportedById          String
  remarks               String?
  /// Default consumption location — single source for this DPR's material
  /// lines. Required at post-time; may be null in draft.
  consumptionLocationId String?
  status                String          @default("draft")
  postedAt              DateTime?
  postedBy              String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  createdBy             String
  updatedBy             String?
  deletedAt             DateTime?
  location              CnLocation?     @relation("DprConsumptionLocation", fields: [consumptionLocationId], references: [id])
  org                   Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project               CnProject       @relation(fields: [projectId], references: [id])
  lines                 CnDPRLine[]
  materials             CnDPRMaterial[]

  @@unique([orgId, projectId, dprDate])
  @@index([orgId])
  @@index([projectId])
  @@index([dprDate])
  @@index([status])
  @@index([deletedAt])
  @@schema("app_quikinfra")
}

/// Materials consumed on a DPR. On post, each row writes a `dpr_consumption`
/// qtyOut row to CnStockLedger against (projectId, consumptionLocationId,
/// itemId). Rate snapshot taken from moving avg at post-time.
model CnDPRMaterial {
  id       String  @id @default(cuid())
  dprId    String
  itemId   String
  uomId    String
  quantity Decimal @db.Decimal(18, 4)
  /// Snapshot unit rate (populated at post-time from prior ledger avg).
  unitRate Decimal @default(0) @db.Decimal(18, 2)
  amount   Decimal @default(0) @db.Decimal(18, 2)
  remarks  String?
  dpr      CnDPR   @relation(fields: [dprId], references: [id], onDelete: Cascade)
  item     CnItem  @relation(fields: [itemId], references: [id])
  uom      CnUOM   @relation(fields: [uomId], references: [id])

  @@index([dprId])
  @@index([itemId])
  @@schema("app_quikinfra")
}

model CnDPRLine {
  id            String     @id @default(cuid())
  dprId         String
  /// What was done: can reference a BOQ item or a free-text description.
  boqItemId     String?
  activity      String
  /// Quantity of work completed today (in uom).
  quantityDone  Decimal    @db.Decimal(18, 4)
  uomId         String?
  /// Labour used today (count of persons).
  labourCount   Int?
  labourHours   Decimal?   @db.Decimal(8, 2)
  /// Machinery used today (free-text summary; ties to CnMachinery later).
  machineryUsed String?
  /// Free-text remarks.
  remarks       String?
  boqItem       CnBOQItem? @relation(fields: [boqItemId], references: [id])
  dpr           CnDPR      @relation(fields: [dprId], references: [id], onDelete: Cascade)
  uom           CnUOM?     @relation(fields: [uomId], references: [id])

  @@index([dprId])
  @@index([boqItemId])
  @@schema("app_quikinfra")
}


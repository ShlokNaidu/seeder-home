  uomId        String?
  rate         Decimal     @db.Decimal(18, 2)
  amount       Decimal     @db.Decimal(18, 2)
  gstRate      Decimal?    @db.Decimal(5, 2)
  taxAmount    Decimal     @default(0) @db.Decimal(18, 2)
  totalAmount  Decimal     @db.Decimal(18, 2)
  completedQty Decimal     @default(0) @db.Decimal(18, 4)
  remarks      String?
  item         CnItem?     @relation(fields: [itemId], references: [id])
  uom          CnUOM?      @relation(fields: [uomId], references: [id])

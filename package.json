{
  "name": "data-seeder",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "eslint .",
    "clean": "pnpm -r exec rm -rf dist && rm -rf node_modules",
    "validate": "tsx apps/seeder/src/index.ts",
    "generate-reports": "tsx apps/seeder/src/generate-reports.ts",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "protobufjs"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "latest",
    "eslint": "latest",
    "prettier": "latest",
    "tsx": "^4.22.4",
    "turbo": "latest",
    "typescript": "latest",
    "typescript-eslint": "^8.62.0"
  }
}
